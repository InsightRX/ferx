TARGET_DIR = ./rust/target
LIBDIR = $(TARGET_DIR)/release
STATLIB = $(LIBDIR)/libferx.a
PKG_LIBS = -L$(LIBDIR) -lferx -lm -ldl -lpthread
all: C_clean
$(SHLIB): $(STATLIB)
$(STATLIB):
	@mkdir -p rust/.cargo
	@echo '[build]' > rust/.cargo/config.toml
	cd rust && cargo build --release
C_clean:
	rm -Rf $(SHLIB) $(STATLIB) $(OBJECTS)
clean:
	rm -Rf $(SHLIB) $(STATLIB) $(OBJECTS) rust/target
